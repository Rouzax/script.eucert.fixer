# =============================================================================
# Section: Certifications (32100-32149)
# =============================================================================

msgctxt "#32100"
msgid "Certifications"
msgstr ""

# Group: Certification format
msgctxt "#32110"
msgid "Certification format"
msgstr ""

msgctxt "#32111"
msgid "Country"
msgstr ""

msgctxt "#32112"
msgid "Select your country's certification system. This determines which certifications are valid and how certifications from other countries are converted."
msgstr ""

msgctxt "#32113"
msgid "Certification prefix"
msgstr ""

msgctxt "#32114"
msgid "Text prepended to the certification value when writing to the library. Leave empty to use the default for your country (e.g. NL: for the Netherlands). Should match the format used by your Kodi info provider."
msgstr ""

# Group: Fallback
msgctxt "#32120"
msgid "Fallback"
msgstr ""

msgctxt "#32121"
msgid "Apply certification when not found"
msgstr ""

msgctxt "#32122"
msgid "Write a not-found certification to items that no source can resolve after the retry window expires."
msgstr ""

msgctxt "#32123"
msgid "Not-found certification"
msgstr ""

msgctxt "#32124"
msgid "Value to write when no source can find a certification and the retry window has expired. NR means Not Rated."
msgstr ""

msgctxt "#32125"
msgid "Retry window (days)"
msgstr ""

msgctxt "#32126"
msgid "Number of days to keep retrying before applying the not-found certification. New releases often get certifications added to TMDB later."
msgstr ""

# =============================================================================
# Section: General (32200-32249)
# =============================================================================

msgctxt "#32200"
msgid "General"
msgstr ""

# Group: Schedule
msgctxt "#32210"
msgid "Schedule"
msgstr ""

msgctxt "#32211"
msgid "Scan interval (hours)"
msgstr ""

msgctxt "#32212"
msgid "How often to check the library for items needing certifications. A scan also runs automatically after each library update. If multiple Kodi instances share a database, only enable this addon on one instance to avoid duplicate lookups."
msgstr ""

msgctxt "#32213"
msgid "API rate limit (seconds)"
msgstr ""

msgctxt "#32214"
msgid "Delay between external API calls. Increase if you hit rate limits."
msgstr ""

# Group: Notifications
msgctxt "#32220"
msgid "Notifications"
msgstr ""

msgctxt "#32221"
msgid "Show notifications"
msgstr ""

msgctxt "#32222"
msgid "Show a Kodi notification when a scan sets new certifications."
msgstr ""

# Group: Debugging
msgctxt "#32230"
msgid "Debugging"
msgstr ""

msgctxt "#32231"
msgid "Enable debug logging"
msgstr ""

msgctxt "#32232"
msgid "Write detailed diagnostic information to a log file in the addon's data folder (addon_data/script.eucert.fixer/logs/)."
msgstr ""

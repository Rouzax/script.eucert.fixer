msgctxt "#32050"
msgid "Country scrapers"
msgstr ""

msgctxt "#32051"
msgid "Enable FSK lookup"
msgstr ""

msgctxt "#32052"
msgid "Search the German rating authority (fsk.de) for ratings. Free API, no key required."
msgstr ""

msgctxt "#32053"
msgid "Enable BBFC lookup"
msgstr ""

msgctxt "#32054"
msgid "Search the British Board of Film Classification (bbfc.co.uk) for ratings. Uses web scraping."
msgstr ""

msgctxt "#32055"
msgid "Enable Medieraadet lookup"
msgstr ""

msgctxt "#32056"
msgid "Search the Danish Media Council (medieraadet.dk) for ratings. Free API, no key required."
msgstr ""


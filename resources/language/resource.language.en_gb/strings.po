# Group: Kijkwijzer.nl (legacy IDs, now under Country scrapers group)
msgctxt "#32031"
msgid "Enable Kijkwijzer lookup"
msgstr ""

msgctxt "#32032"
msgid "Search the Dutch rating authority website (kijkwijzer.nl). Uses web scraping, which may break if the website changes. Currently blocked by bot protection on most connections."
msgstr ""

# Group: Correction
msgctxt "#32040"
msgid "Correction"
msgstr ""

msgctxt "#32041"
msgid "Replace incorrect ratings"
msgstr ""

msgctxt "#32042"
msgid "Also replace existing ratings that are not valid for your selected country (e.g. US ratings like R or PG-13 when your target is NL). When off, only items with no rating are processed."
msgstr ""


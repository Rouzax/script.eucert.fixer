# Section: General (32200-32249)
# =============================================================================

msgctxt "#32200"
msgid "General"
msgstr ""

# Group: Schedule
msgctxt "#32210"
msgid "Schedule"
msgstr ""

msgctxt "#32211"
msgid "Scan interval (hours)"
msgstr ""

msgctxt "#32212"
msgid "How often to check the library for items needing ratings. A scan also runs automatically after each library update. If multiple Kodi instances share a database, only enable this addon on one instance to avoid duplicate API calls."
msgstr ""

msgctxt "#32213"
msgid "API rate limit (seconds)"
msgstr ""

msgctxt "#32214"
msgid "Delay between external API calls. Increase if you hit rate limits."
msgstr ""

# Group: Notifications
msgctxt "#32220"
msgid "Notifications"
msgstr ""

msgctxt "#32221"
msgid "Show notifications"
msgstr ""

msgctxt "#32222"
msgid "Show a Kodi notification after a scan completes with new ratings."
msgstr ""


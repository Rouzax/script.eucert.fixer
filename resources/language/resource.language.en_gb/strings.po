# Section: Ratings (32100-32149)
# =============================================================================

msgctxt "#32100"
msgid "Ratings"
msgstr ""

# Group: Rating format
msgctxt "#32110"
msgid "Rating format"
msgstr ""

msgctxt "#32111"
msgid "Country"
msgstr ""

msgctxt "#32112"
msgid "Select your country's age rating system. This determines which ratings are considered valid and how ratings from other countries are mapped."
msgstr ""

msgctxt "#32113"
msgid "Rating prefix"
msgstr ""

msgctxt "#32114"
msgid "Text prepended to the rating value when writing to the library. Leave empty to use the default for your country. Must match your scraper format (typically your country code followed by a colon, e.g. NL:)."
msgstr ""

# Group: Fallback
msgctxt "#32120"
msgid "Fallback"
msgstr ""

msgctxt "#32121"
msgid "Enable fallback rating"
msgstr ""

msgctxt "#32122"
msgid "Apply a default rating to items that no source can resolve after the retry window expires."
msgstr ""

msgctxt "#32123"
msgid "Fallback rating"
msgstr ""

msgctxt "#32124"
msgid "Rating to apply when no source can find a result and the retry window has expired."
msgstr ""

msgctxt "#32125"
msgid "Retry days"
msgstr ""

msgctxt "#32126"
msgid "Number of days to keep retrying before applying the fallback rating. New releases often get certifications added later."
msgstr ""


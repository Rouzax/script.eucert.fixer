msgstr ""

msgctxt "#32011"
msgid "TMDB API key"
msgstr ""

msgctxt "#32012"
msgid "API key for The Movie Database (themoviedb.org). Required for certification lookups."
msgstr ""

# Group: OMDB
msgctxt "#32020"
msgid "OMDB"
msgstr ""

msgctxt "#32021"
msgid "OMDB API key"
msgstr ""

msgctxt "#32022"
msgid "API key for the Open Movie Database (omdbapi.com). Checked after TMDB and country scrapers when neither has a result."
msgstr ""

# Group: Kijkwijzer.nl (legacy IDs, now under Country scrapers group)
msgctxt "#32031"
msgid "Enable Kijkwijzer lookup"
msgstr ""

msgctxt "#32032"
msgid "Search the Dutch classification authority (kijkwijzer.nl). May be blocked on some systems by the site's bot protection."
msgstr ""

# Group: Correction
msgctxt "#32040"
msgid "Correction"
msgstr ""

msgctxt "#32041"
msgid "Replace incorrect certifications"
msgstr ""

msgctxt "#32042"
msgid "Replace existing certifications that do not match your selected country. This includes certifications from other systems (e.g. US Rated R when your country is NL) and certifications with a different country prefix (e.g. NL:14 when your country is AT). When off, only items with no certification are processed."
msgstr ""

# Group: Country scrapers
msgctxt "#32050"
msgid "Country scrapers"
msgstr ""

msgctxt "#32051"
msgid "Enable FSK lookup"
msgstr ""

msgctxt "#32052"
msgid "Search the German classification authority (fsk.de) for certifications."
msgstr ""

msgctxt "#32053"
msgid "Enable BBFC lookup"
msgstr ""

msgctxt "#32054"
msgid "Search the British Board of Film Classification (bbfc.co.uk) for certifications."
msgstr ""

msgctxt "#32055"
msgid "Enable Medieraadet lookup"
msgstr ""

msgctxt "#32056"
msgid "Search the Danish Media Council (medieraadet.dk) for certifications."
msgstr ""


msgctxt "#32001"
msgid "Providers"
msgstr ""

# Group: TMDB
msgctxt "#32010"
msgid "TMDB"
msgstr ""

msgctxt "#32011"
msgid "TMDB API key"
msgstr ""

msgctxt "#32012"
msgid "API key for The Movie Database (themoviedb.org). Required for rating lookups."
msgstr ""

# Group: OMDB
msgctxt "#32020"
msgid "OMDB"
msgstr ""

msgctxt "#32021"
msgid "OMDB API key"
msgstr ""

msgctxt "#32022"
msgid "API key for the Open Movie Database (omdbapi.com). Used as a fallback when TMDB has no rating."
msgstr ""

# Group: Kijkwijzer.nl
msgctxt "#32030"
msgid "Kijkwijzer.nl"
msgstr ""

msgctxt "#32031"
msgid "Enable kijkwijzer.nl lookup"
msgstr ""

msgctxt "#32032"
msgid "Search the Dutch rating authority website (kijkwijzer.nl) when TMDB and OMDB have no result. Uses web scraping, which may break if the website changes its layout."
msgstr ""

# Group: Correction
msgctxt "#32040"
msgid "Correction"
msgstr ""

msgctxt "#32041"
msgid "Replace incorrect ratings"
msgstr ""

msgctxt "#32042"
msgid "Also replace existing ratings that are not valid Kijkwijzer values (e.g. US ratings like R or PG-13). When off, only items with no rating are processed."
msgstr ""

# =============================================================================
# Section: Ratings (32100-32149)
# =============================================================================

msgctxt "#32100"
msgid "Ratings"
msgstr ""

# Group: Rating format
msgctxt "#32110"
msgid "Rating format"
msgstr ""

msgctxt "#32111"
msgid "Target country"
msgstr ""

msgctxt "#32112"
msgid "ISO 3166-1 country code for the rating system to use (e.g. NL for Kijkwijzer)."
msgstr ""

msgctxt "#32113"
msgid "Rating prefix"
msgstr ""

msgctxt "#32114"
msgid "Text prepended to the rating value when writing to the library. Must match your scraper format. For the TMDb scraper this is typically your country code followed by a colon (e.g. NL:)."
msgstr ""

# Group: Fallback
msgctxt "#32120"
msgid "Fallback"
msgstr ""

msgctxt "#32121"
msgid "Enable fallback rating"
msgstr ""

msgctxt "#32122"
msgid "Apply a default rating to items that no source can resolve after the retry window expires."
msgstr ""

msgctxt "#32123"
msgid "Fallback rating"
msgstr ""

msgctxt "#32124"
msgid "Rating to apply when no source can find a result and the retry window has expired."
msgstr ""

msgctxt "#32125"
msgid "Retry days"
msgstr ""

msgctxt "#32126"
msgid "Number of days to keep retrying before applying the fallback rating. New releases often get certifications added later."
msgstr ""


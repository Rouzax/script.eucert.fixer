<?xml version="1.0" encoding="UTF-8"?>
<settings version="1">
    <section id="script.kijkwijzer.ratings">
        <!-- Tab: Providers -->
        <category id="providers" label="32001">
            <group id="tmdb_group" label="32010">
                <setting id="tmdb_api_key" type="string" label="32011" help="32012">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="omdb_group" label="32020">
                <setting id="omdb_api_key" type="string" label="32021" help="32022">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="kijkwijzer_group" label="32030">
                <setting id="enable_kijkwijzer" type="boolean" label="32031" help="32032">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="correction_group" label="32040">
                <setting id="replace_incorrect" type="boolean" label="32041" help="32042">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>

        <!-- Tab: Ratings -->
        <category id="ratings" label="32100">
            <group id="format_group" label="32110">
                <setting id="target_country" type="string" label="32111" help="32112">
                    <level>0</level>
                    <default>NL</default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="rating_prefix" type="string" label="32113" help="32114">
                    <level>1</level>
                    <default>NL:</default>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="fallback_group" label="32120">
                <setting id="enable_fallback" type="boolean" label="32121" help="32122">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="fallback_rating" type="string" label="32123" help="32124">
                    <level>1</level>
                    <default>NR</default>
                    <dependencies>
                        <dependency type="visible" setting="enable_fallback">true</dependency>
                    </dependencies>
                    <control type="edit" format="string" />
                </setting>
                <setting id="retry_days" type="integer" label="32125" help="32126">
                    <level>1</level>
                    <default>30</default>
                    <dependencies>
                        <dependency type="visible" setting="enable_fallback">true</dependency>
                    </dependencies>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>365</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="spinner" format="integer" />
                </setting>
            </group>
        </category>

        <!-- Tab: General -->
        <category id="general" label="32200">
            <group id="schedule_group" label="32210">
                <setting id="scan_interval" type="integer" label="32211" help="32212">
                    <level>0</level>
                    <default>24</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>168</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="spinner" format="integer" />
                </setting>
                <setting id="rate_limit" type="number" label="32213" help="32214">
                    <level>2</level>
                    <default>0.25</default>
                    <constraints>
                        <minimum>0.1</minimum>
                        <maximum>5.0</maximum>
                        <step>0.05</step>
                    </constraints>
                    <control type="spinner" format="number" />
                </setting>
            </group>
            <group id="notifications_group" label="32220">
                <setting id="show_notifications" type="boolean" label="32221" help="32222">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="debug_group" label="32230">
                <setting id="logging" type="boolean" label="32231" help="32232">
                    <level>2</level>
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>
    </section>
</settings>

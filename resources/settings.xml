<?xml version="1.0" encoding="UTF-8"?>
<settings version="1">
    <section id="script.eucert.fixer">
        <!-- Tab: Providers -->
        <category id="providers" label="32001">
            <group id="tmdb_group" label="32010">
                <setting id="tmdb_api_key" type="string" label="32011" help="32012">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="omdb_group" label="32020">
                <setting id="omdb_api_key" type="string" label="32021" help="32022">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="scraper_group" label="32050">
                <setting id="enable_fsk" type="boolean" label="32051" help="32052">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="enable_bbfc" type="boolean" label="32053" help="32054">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="enable_medieraadet" type="boolean" label="32055" help="32056">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="enable_kijkwijzer" type="boolean" label="32031" help="32032">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="correction_group" label="32040">
                <setting id="replace_incorrect" type="boolean" label="32041" help="32042">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>

        <!-- Tab: Ratings -->
        <category id="ratings" label="32100">
            <group id="format_group" label="32110">
                <setting id="country" type="integer" label="32111" help="32112">
                    <level>0</level>
                    <default>0</default>
                    <constraints>
                        <options>
                            <option label="32060">0</option>
                            <option label="32061">1</option>
                            <option label="32062">2</option>
                            <option label="32063">3</option>
                            <option label="32064">4</option>
                            <option label="32065">5</option>
                            <option label="32066">6</option>
                            <option label="32067">7</option>
                            <option label="32068">8</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string" />
                </setting>
                <setting id="override_prefix" type="boolean" label="32115" help="32116">
                    <level>2</level>
                    <default>false</default>
                    <control type="toggle" />
                </setting>
                <setting id="rating_prefix" type="string" label="32113" help="32114">
                    <level>2</level>
                    <default></default>
                    <dependencies>
                        <dependency type="visible" setting="override_prefix">true</dependency>
                    </dependencies>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="fallback_group" label="32120">
                <setting id="enable_fallback" type="boolean" label="32121" help="32122">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="fallback_rating" type="string" label="32123" help="32124">
                    <level>1</level>
                    <default>NR</default>
                    <dependencies>
                        <dependency type="visible" setting="enable_fallback">true</dependency>
                    </dependencies>
                    <control type="edit" format="string" />
                </setting>
                <setting id="retry_days" type="integer" label="32125" help="32126">
                    <level>1</level>
                    <default>30</default>
                    <dependencies>
                        <dependency type="visible" setting="enable_fallback">true</dependency>
                    </dependencies>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>365</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="spinner" format="integer" />
                </setting>
            </group>
        </category>

        <!-- Tab: General -->
        <category id="general" label="32200">
            <group id="schedule_group" label="32210">
                <setting id="scan_interval" type="integer" label="32211" help="32212">
                    <level>0</level>
                    <default>24</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>168</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="spinner" format="integer" />
                </setting>
                <setting id="rate_limit" type="number" label="32213" help="32214">
                    <level>2</level>
                    <default>0.25</default>
                    <constraints>
                        <minimum>0.1</minimum>
                        <maximum>5.0</maximum>
                        <step>0.05</step>
                    </constraints>
                    <control type="spinner" format="number" />
                </setting>
            </group>
            <group id="notifications_group" label="32220">
                <setting id="show_notifications" type="boolean" label="32221" help="32222">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="debug_group" label="32230">
                <setting id="logging" type="boolean" label="32231" help="32232">
                    <level>2</level>
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>
    </section>
</settings>

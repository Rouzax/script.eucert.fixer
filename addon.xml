<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.kijkwijzer.ratings"
       name="Kijkwijzer Ratings"
       version="0.2.0~alpha1"
       provider-name="Rouzax">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" version="2.28.0" />
    </requires>
    <extension point="xbmc.service"
               library="service.py"
               start="login" />
    <extension point="xbmc.python.library"
               library="resources/lib" />
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <license>MIT</license>
        <summary lang="en_GB">Backfill missing age ratings in your Kodi library</summary>
        <description lang="en_GB">Automatically fills missing age ratings (mpaa) for movies and TV shows using TMDB, OMDB, and kijkwijzer.nl. Runs in the background and checks periodically for items without ratings.</description>
    </extension>
</addon>
